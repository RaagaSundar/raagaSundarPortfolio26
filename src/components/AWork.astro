---
const { caption, cssClass, detail, index, total } = Astro.props

// A short reference key shown on the card.
const key = Math.random().toString(36).slice(2, 6) + '-' + index + '/' + total
---

<a-work class={cssClass}>
  <div class="a__inner">
    <button class="a__open js-open" type="button">
      <div class="a__face">
        <span class="a__face__text">{caption}</span>
      </div>

      <div class="a__caption">
        <div class="a__caption__text">Open</div>

        <div class="a__caption__key">
          #{key}
        </div><!-- .a__caption__key -->
      </div><!-- .a__caption -->
    </button>

    <div class="a__detail" hidden set:html={detail}></div>
  </div><!-- .a__inner -->
</a-work>

<script>
  class AWork extends HTMLElement {
    static observedAttributes = ['progress']

    button: HTMLButtonElement
    isInview: boolean

    /**
     * Init
     */
    connectedCallback() {
      this.button = this.querySelector('.js-open')
      this.isInview = false

      this.button.addEventListener('click', this.onClick.bind(this))
    }

    /**
     * Attribute changed
     */
    attributeChangedCallback(name, oldValue, newValue) {
      if (name === 'progress') {
        this.style.setProperty('--progress', newValue)

        if (newValue === '1' || newValue === '-1') {
          if (this.isInview) {
            this.classList.remove('is-inview')
            this.isInview = false
          }
        } else {
          if (!this.isInview) {
            this.classList.add('is-inview')
            this.isInview = true
          }
        }
      }
    }

    /**
     * On click: open the in-site panel for this card.
     */
    onClick(event: MouseEvent) {
      event.preventDefault()

      const detail = this.querySelector('.a__detail') as HTMLElement

      this.dispatchEvent(
        new CustomEvent('open-card', {
          bubbles: true,
          detail: { html: detail ? detail.innerHTML : '' },
        })
      )
    }
  }

  customElements.define('a-work', AWork)
</script>

<style lang="scss">
  a-work {
    position: relative;
    top: 0;
    left: 0;

    display: block;
    margin: 0;
    padding: 0.5rem 0.5rem 0;

    background: color(secondary);
    content-visibility: hidden;

    transform-style: preserve-3d;

    will-change: transform;

    @include mq(phone) {
      padding: 0.25rem;
    }

    .a__inner {
      display: block;
      margin: 0;
      padding: 0;
    }

    .a__open {
      display: block;
      margin: 0;
      padding: 0;
      width: 100%;

      appearance: none;
      background: none;
      border: 0;
      cursor: pointer;

      color: inherit;
      font: inherit;
    }

    .a__face {
      @include flex(column, center, center);

      width: 22rem;
      height: 13rem;
      padding: 1.5rem;

      background: color(primary);

      @include mq(phone) {
        width: 64vw;
        height: 38vw;
        padding: 1rem;
      }
    }

    .a__face__text {
      color: color(secondary);
      font: 700 1.5rem / 1.15 font-family(bigger);
      text-align: center;
      text-transform: uppercase;
      text-wrap: balance;

      @include mq(phone) {
        font-size: 1.05rem;
      }
    }

    .a__caption {
      @include flex(row, center, space-between);

      padding: 0.5rem 0.5rem;

      color: color(primary);
      font: 700 11px / 1 font-family(fraktion);
      letter-spacing: 0.15em;
      text-align: right;
      text-transform: uppercase;

      @include mq(phone) {
        display: none;
      }
    }

    &.is-inview {
      content-visibility: visible;
    }
  }
</style>
